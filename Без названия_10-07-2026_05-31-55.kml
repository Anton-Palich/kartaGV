<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2"><Document><Style id="strokeColor:595959e6_strokeWidth:5"><LineStyle><color>e6595959</color><width>5</width></LineStyle></Style><Style id="id1783636281412806076"><LineStyle><color>e64345ed</color><width>5</width></LineStyle></Style><Style id="fillColor:ed454399_strokeColor:ed4543e6_strokeWidth:5"><LineStyle><color>e64345ed</color><width>5</width></LineStyle><PolyStyle><color>994345ed</color><fill>1</fill><outline>1</outline></PolyStyle></Style><ExtendedData><Data name="creator"><value><![CDATA[Yandex Map Constructor]]></value></Data></ExtendedData><name><![CDATA[Без названия]]></name><description/><Folder><Placemark><name/><description><![CDATA[Битва<br/>]]></description><styleUrl>#fillColor:ed454399_strokeColor:ed4543e6_strokeWidth:5</styleUrl><Polygon><outerBoundaryIs><LinearRing><coordinates>92.65197747949192,56.22835358376614 92.80303949121078,56.17859742822968 92.68218988183563,56.11957160948385 92.59429925683581,56.151012273212 92.65197747949192,56.22835358376614</coordinates></LinearRing></outerBoundaryIs></Polygon></Placemark><Placemark><name/><description><![CDATA[Диоверсия на дороге]]></description><styleUrl>#strokeColor:595959e6_strokeWidth:5</styleUrl><LineString><coordinates>92.8182315230712,56.03528321222474 92.82612794641105,56.035955947699186 92.83093446496571,56.03989601901107 92.8432511687621,56.04006418379099 92.8452681899413,56.04042453443353 92.85256379846183,56.0453730079691</coordinates></LineString></Placemark><Placemark><name/><description/><styleUrl>#strokeColor:595959e6_strokeWidth:5</styleUrl><LineString><coordinates>92.83531183007804,56.03977346160184 92.85024636987295,56.04779652973042</coordinates></LineString></Placemark><Placemark><name/><description><![CDATA[КАРТА КАРТА КАРТА]]></description><styleUrl>#id1783636281412806076</styleUrl><LineString><coordinates>92.7975463271464,55.97243278721698 92.92612069848425,55.99110328578022 92.91238778832803,55.951730679349374 92.78570169213664,55.944024730424424 92.85814279321086,55.965693786942616 92.90517801049597,55.98225036336371 92.77814859155069,55.95885731110495 92.76647561791786,55.982539077722244 92.85882943871864,55.98994867220188 92.91792462229293,56.00040013788395 92.9198128974394,55.995301564893346</coordinates></LineString></Placemark><Placemark><name/><description/><Style><IconStyle><color>ffff981e</color><Icon><href>https://api-maps.yandex.ru/i/0.4/micro/pmbls.png</href></Icon><hotSpot x="7" y="28" xunits="pixels" yunits="insetPixels"/></IconStyle></Style><Point><coordinates>92.81728738549785,56.06093248693578</coordinates></Point></Placemark><Placemark><name/><description><![CDATA[<!DOCTYPE html><br/><html lang="ru"><br/><head><br/>  <meta charset="UTF-8"><br/>  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes"><br/>  <title>Редактор описания объекта · Яндекс Карты</title><br/>  <style><br/>    * {<br/>      margin: 0;<br/>      padding: 0;<br/>      box-sizing: border-box;<br/>    }<br/><br/>    body {<br/>      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;<br/>      background: #f3f4f6;<br/>      display: flex;<br/>      justify-content: center;<br/>      align-items: center;<br/>      min-height: 100vh;<br/>      margin: 0;<br/>      padding: 20px;<br/>    }<br/><br/>    /* Карточка формы */<br/>    .editor-modal {<br/>      background: #ffffff;<br/>      border-radius: 20px;<br/>      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);<br/>      width: 100%;<br/>      max-width: 600px;<br/>      padding: 28px 24px 24px;<br/>      transition: all 0.2s ease;<br/>    }<br/><br/>    .editor-header {<br/>      display: flex;<br/>      align-items: center;<br/>      justify-content: space-between;<br/>      margin-bottom: 20px;<br/>    }<br/><br/>    .editor-header h2 {<br/>      font-size: 1.5rem;<br/>      font-weight: 600;<br/>      color: #1f2937;<br/>      display: flex;<br/>      align-items: center;<br/>      gap: 8px;<br/>    }<br/><br/>    .editor-header h2::before {<br/>      content: "📍";<br/>      font-size: 1.5rem;<br/>    }<br/><br/>    .close-btn {<br/>      background: none;<br/>      border: none;<br/>      font-size: 1.5rem;<br/>      color: #6b7280;<br/>      cursor: pointer;<br/>      width: 36px;<br/>      height: 36px;<br/>      border-radius: 50%;<br/>      display: flex;<br/>      align-items: center;<br/>      justify-content: center;<br/>      transition: background 0.15s;<br/>    }<br/><br/>    .close-btn:hover {<br/>      background: #f3f4f6;<br/>      color: #111827;<br/>    }<br/><br/>    .form-group {<br/>      margin-bottom: 18px;<br/>    }<br/><br/>    label {<br/>      display: block;<br/>      font-size: 0.9rem;<br/>      font-weight: 500;<br/>      color: #374151;<br/>      margin-bottom: 6px;<br/>      letter-spacing: 0.01em;<br/>    }<br/><br/>    .hint {<br/>      font-size: 0.8rem;<br/>      color: #9ca3af;<br/>      margin-left: 4px;<br/>      font-weight: 400;<br/>    }<br/><br/>    input[type="text"],<br/>    textarea {<br/>      width: 100%;<br/>      padding: 12px 14px;<br/>      border: 1px solid #e5e7eb;<br/>      border-radius: 14px;<br/>      font-size: 0.95rem;<br/>      font-family: inherit;<br/>      background: #f9fafb;<br/>      transition: border 0.15s, box-shadow 0.15s;<br/>      outline: none;<br/>      resize: vertical;<br/>    }<br/><br/>    input[type="text"]:focus,<br/>    textarea:focus {<br/>      border-color: #facc15;<br/>      box-shadow: 0 0 0 3px rgba(250, 204, 21, 0.25);<br/>      background: #ffffff;<br/>    }<br/><br/>    textarea {<br/>      min-height: 90px;<br/>    }<br/><br/>    .media-section {<br/>      background: #f9fafb;<br/>      border-radius: 16px;<br/>      padding: 16px;<br/>      margin-top: 6px;<br/>    }<br/><br/>    .media-grid {<br/>      display: flex;<br/>      flex-wrap: wrap;<br/>      gap: 12px;<br/>      margin-top: 10px;<br/>    }<br/><br/>    .file-upload-area {<br/>      flex: 1 1 140px;<br/>      border: 2px dashed #d1d5db;<br/>      border-radius: 14px;<br/>      display: flex;<br/>      flex-direction: column;<br/>      align-items: center;<br/>      justify-content: center;<br/>      padding: 18px 10px;<br/>      cursor: pointer;<br/>      transition: background 0.2s, border-color 0.2s;<br/>      background: #ffffff;<br/>      text-align: center;<br/>      min-height: 120px;<br/>    }<br/><br/>    .file-upload-area:hover {<br/>      border-color: #fbbf24;<br/>      background: #fffbeb;<br/>    }<br/><br/>    .file-upload-area span {<br/>      font-size: 1.8rem;<br/>      margin-bottom: 6px;<br/>    }<br/><br/>    .file-upload-area .upload-text {<br/>      font-size: 0.8rem;<br/>      color: #6b7280;<br/>      font-weight: 500;<br/>    }<br/><br/>    .file-upload-area input[type="file"] {<br/>      display: none;<br/>    }<br/><br/>    .preview-item {<br/>      position: relative;<br/>      width: 100px;<br/>      height: 100px;<br/>      border-radius: 12px;<br/>      overflow: hidden;<br/>      background: #e5e7eb;<br/>      display: flex;<br/>      align-items: center;<br/>      justify-content: center;<br/>      flex-shrink: 0;<br/>      box-shadow: 0 2px 6px rgba(0,0,0,0.05);<br/>    }<br/><br/>    .preview-item img,<br/>    .preview-item video {<br/>      width: 100%;<br/>      height: 100%;<br/>      object-fit: cover;<br/>    }<br/><br/>    .preview-item .remove-media {<br/>      position: absolute;<br/>      top: 4px;<br/>      right: 4px;<br/>      background: rgba(0,0,0,0.65);<br/>      color: white;<br/>      border: none;<br/>      border-radius: 50%;<br/>      width: 20px;<br/>      height: 20px;<br/>      font-size: 14px;<br/>      line-height: 1;<br/>      cursor: pointer;<br/>      display: flex;<br/>      align-items: center;<br/>      justify-content: center;<br/>      backdrop-filter: blur(4px);<br/>    }<br/><br/>    .video-link-input {<br/>      margin-top: 12px;<br/>    }<br/><br/>    .video-link-input input {<br/>      width: 100%;<br/>    }<br/><br/>    .action-buttons {<br/>      display: flex;<br/>      gap: 10px;<br/>      justify-content: flex-end;<br/>      margin-top: 24px;<br/>    }<br/><br/>    .btn {<br/>      padding: 12px 22px;<br/>      border-radius: 14px;<br/>      font-weight: 600;<br/>      font-size: 0.95rem;<br/>      border: none;<br/>      cursor: pointer;<br/>      transition: background 0.2s, transform 0.1s;<br/>      letter-spacing: 0.02em;<br/>    }<br/><br/>    .btn:active {<br/>      transform: scale(0.97);<br/>    }<br/><br/>    .btn-primary {<br/>      background: #fbbf24;<br/>      color: #1e293b;<br/>      box-shadow: 0 4px 10px rgba(251, 191, 36, 0.3);<br/>    }<br/><br/>    .btn-primary:hover {<br/>      background: #f59e0b;<br/>    }<br/><br/>    .btn-secondary {<br/>      background: #f3f4f6;<br/>      color: #374151;<br/>    }<br/><br/>    .btn-secondary:hover {<br/>      background: #e5e7eb;<br/>    }<br/><br/>    .note {<br/>      font-size: 0.8rem;<br/>      color: #6b7280;<br/>      margin-top: 12px;<br/>      text-align: center;<br/>      border-top: 1px solid #f3f4f6;<br/>      padding-top: 12px;<br/>    }<br/><br/>    /* Адаптив */<br/>    @media (max-width: 480px) {<br/>      .editor-modal {<br/>        padding: 20px 16px;<br/>      }<br/>      .media-grid {<br/>        flex-direction: column;<br/>      }<br/>    }<br/>  </style><br/></head><br/><body><br/>  <!-- Форма редактора описания метки / объекта Яндекс Карт --><br/>  <div class="editor-modal" role="dialog" aria-labelledby="editor-title"><br/>    <div class="editor-header"><br/>      <h2 id="editor-title">Описание объекта</h2><br/>      <button class="close-btn" title="Закрыть" onclick="alert('Форма закрыта (демо)')">✕</button><br/>    </div><br/><br/>    <!-- Текстовые поля --><br/>    <div class="form-group"><br/>      <label for="object-name">Название метки <span class="hint">(обязательно)</span></label><br/>      <input type="text" id="object-name" placeholder="Введите название объекта" value="Парк Горького" required><br/>    </div><br/><br/>    <div class="form-group"><br/>      <label for="object-desc">Описание</label><br/>      <textarea id="object-desc" placeholder="Добавьте подробное описание, историю или заметку...">Центральный парк культуры и отдыха. Прекрасное место для прогулок и пикников.</textarea><br/>    </div><br/><br/>    <!-- ========== ДОБАВЛЕННЫЙ БЛОК (ВНИЗУ ОСНОВНОГО ТЕКСТА) ========== --><br/>    <div class="form-group" style="background: #f8fafc; padding: 16px; border-radius: 16px; border-left: 5px solid #facc15; margin-bottom: 20px;"><br/>      <div style="display: flex; flex-direction: column; gap: 10px;"><br/>        <h3 style="margin:0; font-size: 1.2rem; font-weight: 600; color: #1e293b;">НОВЫЙ ПРОЕКТ</h3><br/>        <p style="margin:0; font-size: 0.95rem; color: #475569; font-weight: 500;">ВСЕМ ПРИВЕТ МЫ ОТКРЫВАЕМ ПРОЕКТ</p><br/>        <br/>        <!-- Место для вашего фото. Замените `ваше_фото.jpg` на путь к загруженному файлу --><br/>        <img src="ваше_фото.jpg" alt="Фото нового проекта" style="width: 100%; max-height: 350px; object-fit: cover; border-radius: 12px; margin-top: 6px;"><br/>      </div><br/>    </div><br/>    <!-- ================================================================== --><br/><br/>    <!-- Блок медиа: фото и видео --><br/>    <div class="media-section"><br/>      <label style="margin-bottom: 4px;">📸 Фотографии</label><br/>      <div class="media-grid" id="photo-previews"><br/>        <!-- Динамические превью фото --><br/>      </div><br/>      <!-- Кнопка загрузки фото --><br/>      <label class="file-upload-area" for="photo-upload" style="margin-top: 8px;"><br/>        <span>🖼️</span><br/>        <span class="upload-text">Загрузить фото</span><br/>        <input type="file" id="photo-upload" accept="image/*" multiple><br/>      </label><br/><br/>      <!-- Видео: либо файл, либо ссылка --><br/>      <div style="margin-top: 20px;"><br/>        <label style="margin-bottom: 8px;">🎬 Видео</label><br/>        <div class="media-grid" id="video-previews"><br/>          <!-- Динамические превью видео --><br/>        </div><br/>        <div style="display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap;"><br/>          <label class="file-upload-area" for="video-upload" style="flex: 1; min-width: 130px; padding: 14px;"><br/>            <span>📁</span><br/>            <span class="upload-text">Загрузить файл</span><br/>            <input type="file" id="video-upload" accept="video/*"><br/>          </label><br/>          <div class="video-link-input" style="flex: 2; min-width: 180px;"><br/>            <label for="video-url">Или ссылка на видео</label><br/>            <input type="text" id="video-url" placeholder="https://..."><br/>          </div><br/>        </div><br/>      </div><br/>    </div><br/><br/>    <!-- Кнопки действий --><br/>    <div class="action-buttons"><br/>      <button class="btn btn-secondary" type="button" onclick="alert('Отмена (демо)')">Отмена</button><br/>      <button class="btn btn-primary" type="button" id="save-btn">💾 Сохранить описание</button><br/>    </div><br/>    <div class="note"><br/>      Поддерживается загрузка фото, видеофайлов и ссылок на видео. Данные можно сохранить в балун метки Яндекс Карт.<br/>    </div><br/>  </div><br/><br/>  <script><br/>    (function() {<br/>      // --- Хранилище медиафайлов (в реальном проекте можно синхронизировать с API карт) ---<br/>      const photoFiles = new DataTransfer(); // для input[type=file] photos<br/>      const videoFile = new DataTransfer();   // для одного видеофайла<br/><br/>      // DOM элементы<br/>      const photoUpload = document.getElementById('photo-upload');<br/>      const videoUpload = document.getElementById('video-upload');<br/>      const videoUrlInput = document.getElementById('video-url');<br/>      const photoPreviewsContainer = document.getElementById('photo-previews');<br/>      const videoPreviewsContainer = document.getElementById('video-previews');<br/>      const saveBtn = document.getElementById('save-btn');<br/><br/>      // --- Функции рендеринга превью ---<br/>      function renderPhotoPreviews() {<br/>        photoPreviewsContainer.innerHTML = '';<br/>        const files = Array.from(photoFiles.files);<br/>        files.forEach((file, index) => {<br/>          const reader = new FileReader();<br/>          reader.onload = (e) => {<br/>            const div = document.createElement('div');<br/>            div.className = 'preview-item';<br/>            div.innerHTML = `<br/>              <img src="${e.target.result}" alt="photo-${index}"><br/>              <button class="remove-media" data-type="photo" data-index="${index}">×</button><br/>            `;<br/>            photoPreviewsContainer.appendChild(div);<br/>          };<br/>          reader.readAsDataURL(file);<br/>        });<br/>      }<br/><br/>      function renderVideoPreview() {<br/>        videoPreviewsContainer.innerHTML = '';<br/>        const files = Array.from(videoFile.files);<br/>        if (files.length > 0) {<br/>          const file = files[0];<br/>          const url = URL.createObjectURL(file);<br/>          const div = document.createElement('div');<br/>          div.className = 'preview-item';<br/>          div.innerHTML = `<br/>            <video src="${url}" controls muted style="width:100%;height:100%;object-fit:cover;"></video><br/>            <button class="remove-media" data-type="video">×</button><br/>          `;<br/>          videoPreviewsContainer.appendChild(div);<br/>        }<br/>      }<br/><br/>      // Обработчики добавления файлов<br/>      photoUpload.addEventListener('change', (e) => {<br/>        const newFiles = Array.from(e.target.files);<br/>        newFiles.forEach(file => photoFiles.items.add(file));<br/>        renderPhotoPreviews();<br/>        photoUpload.value = ''; // сброс, чтобы можно было повторно выбрать те же файлы<br/>      });<br/><br/>      videoUpload.addEventListener('change', (e) => {<br/>        const files = e.target.files;<br/>        if (files.length === 0) return;<br/>        // Заменяем предыдущий видеофайл (поддерживаем одно видео)<br/>        videoFile.items.clear();<br/>        videoFile.items.add(files[0]);<br/>        renderVideoPreview();<br/>        videoUpload.value = '';<br/>      });<br/><br/>      // Удаление медиа по клику на крестик<br/>      document.addEventListener('click', (e) => {<br/>        if (e.target.classList.contains('remove-media')) {<br/>          const type = e.target.dataset.type;<br/>          if (type === 'photo') {<br/>            const index = parseInt(e.target.dataset.index, 10);<br/>            // Удаляем файл из DataTransfer<br/>            const dt = new DataTransfer();<br/>            const filesArr = Array.from(photoFiles.files);<br/>            filesArr.splice(index, 1);<br/>            filesArr.forEach(f => dt.items.add(f));<br/>            // Заменяем photoFiles<br/>            photoFiles.items.clear();<br/>            filesArr.forEach(f => photoFiles.items.add(f));<br/>            renderPhotoPreviews();<br/>          } else if (type === 'video') {<br/>            videoFile.items.clear();<br/>            renderVideoPreview();<br/>          }<br/>        }<br/>      });<br/><br/>      // Обработка ввода ссылки на видео (можно показывать иконку-ссылку)<br/>      videoUrlInput.addEventListener('input', () => {<br/>        // Визуально можно подсветить, но превью не меняем<br/>      });<br/><br/>      // --- Сохранение (имитация) ---<br/>      saveBtn.addEventListener('click', () => {<br/>        const name = document.getElementById('object-name').value.trim();<br/>        const desc = document.getElementById('object-desc').value.trim();<br/>        const photoCount = photoFiles.files.length;<br/>        const videoFilePresent = videoFile.files.length > 0;<br/>        const videoLink = videoUrlInput.value.trim();<br/><br/>        if (!name) {<br/>          alert('Пожалуйста, введите название метки.');<br/>          return;<br/>        }<br/><br/>        // Сбор данных для интеграции с Яндекс Картами<br/>        const formData = {<br/>          name,<br/>          description: desc,<br/>          photos: Array.from(photoFiles.files).map(f => f.name),<br/>          video: videoFilePresent ? videoFile.files[0].name : null,<br/>          videoUrl: videoLink || null,<br/>        };<br/><br/>        console.log('📋 Данные для сохранения в балун/метку:', formData);<br/>        alert(`✅ Описание "${name}" собрано.\nФото: ${photoCount} шт.\nВидео: ${videoFilePresent ? 'файл загружен' : (videoLink ? 'ссылка' : 'нет')}\n\n(См. консоль для подробностей)`);<br/>        <br/>        // Здесь должна быть логика сохранения в объект Яндекс Карт, например:<br/>        // myPlacemark.properties.set('balloonContent', сформированный HTML);<br/>        // myPlacemark.properties.set('description', desc);<br/>        // Для демонстрации просто выведем в консоль.<br/>      });<br/><br/>      // Инициализация начальных превью (пусто, но можно загрузить демо)<br/>      renderPhotoPreviews();<br/>      renderVideoPreview();<br/><br/>    })();<br/>  </script><br/></body><br/></html>]]></description><Style><IconStyle><color>ffff981e</color><Icon><href>https://api-maps.yandex.ru/i/0.4/micro/pmbls.png</href></Icon><hotSpot x="7" y="28" xunits="pixels" yunits="insetPixels"/></IconStyle></Style><Point><coordinates>92.85925859216198,56.06950040131439</coordinates></Point></Placemark><Placemark><name/><description/><Style><IconStyle><color>ffff981e</color><Icon><href>https://api-maps.yandex.ru/i/0.4/micro/pmbls.png</href></Icon><hotSpot x="7" y="28" xunits="pixels" yunits="insetPixels"/></IconStyle></Style><Point><coordinates>92.81831735375968,56.05567098356047</coordinates></Point></Placemark><Placemark><name/><description/><Style><IconStyle><color>ffff981e</color><Icon><href>https://api-maps.yandex.ru/i/0.4/micro/pmbls.png</href></Icon><hotSpot x="7" y="28" xunits="pixels" yunits="insetPixels"/></IconStyle></Style><Point><coordinates>92.83016198876913,56.06700379181426</coordinates></Point></Placemark></Folder></Document></kml>